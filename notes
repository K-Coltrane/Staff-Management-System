<?php
if(isset($_POST["login"])) {

    $username = $_POST["username"];
    $password = $_POST["password"];

    if(empty($username)) {
        echo"username is missing";
    }
    elseif(empty($password)){
        echo"password is missing"; 
    }
    else{
        echo"Hello {$username}";
    }
}
?>




